<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.onfit.mapper.MemberMapper">

    <update id="updatePersonalColor">
        UPDATE member
        SET personal_color = #{personalColor}
        WHERE id = #{id}
    </update>

</mapper>